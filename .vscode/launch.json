{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Python Debugger: Current File",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal"
        },
        // 059 / transformer_s4_flex_attn.sh
        {
            "name": "Python: Transformer S4 Flex Attn ",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/training/src/anemoi/training/train/train.py",
            "console": "integratedTerminal",
            "justMyCode": false,
            "envFile": "${workspaceFolder}/.env",
            "env": {
                // "TRCH_COMPILE":"1",
                // "PYTHONPATH": "${workspaceFolder}",
                "_PYTEST_RAISE": "1",
                "TORCH_NCCL_ENABLE_MONITORING":"0",
                // "CUDA_LAUNCH_BLOCKING": "1",
                // "TORCH_USE_CUDA_DSA": "1",
                // "TORCH_LOGS":"+guards,+dynamo,+recompiles,+graph_breaks,+output_code,+inductor",
                // "TORCH_LOGS":"+guards,+dynamo,+recompiles,+graph_breaks,+output_code",
                // "TORCH_LOGS": "+dynamo,+recompiles,+graph_breaks",
                // "TORCH_LOGS": "+dynamo,+aot,+inductor,+aot_graphs",
                // "TORCH_LOGS": "+dynamo,+graph_breaks,+guards,+recompiles",
                // "TORCH_LOGS": "+dynamo,+graph_breaks,+recompiles",
                // "TORCH_LOGS_OUT": "dynamo_transformer_s4_flex_attn.log",

                // "TORCH_COMPILE_DEBUG": "1",
                // "TORCHDYNAMO_VERBOSE": "1",
                "SLURM_GPUS_PER_NODE": "1",
                "SLURM_NTASKS_PER_NODE": "1",
                "SLURM_NNODES": "1",
                // "TORCHDYNAMO_VERBOSE": "1",
                // "TORCHINDUCTOR_FX_GRAPH_CACHE": "0"
            },
            "args": [
                "--config-name=config", 
                "hardware=private_atos",
                "model=transformer_flex",

                "diagnostics.log.mlflow.run_name=debug_flex_knn",
                "diagnostics.log.mlflow.offline=true",

                // "graph.nodes.hidden0.node_builder.resolution=3",
                // "training.max_epochs=250",
                // "training.max_epochs=10",

                "training.precision=bf16-mixed",
                "training.max_steps=2000",

                "graph.edges=[]",
                
                "model.processor.num_layers=1",
                "model.processor.num_heads=8",
                "model.processor.mlp_hidden_ratio=4",
                "model.processor.num_chunks=1",
                "model.encoder.num_heads=8",
                "model.decoder.num_heads=8",
                "model.processor_block_mask.attention_span=128",

                "model.num_channels=128",
                
                "dataloader.batch_size.training=2",
                "dataloader.batch_size.validation=2",
                "dataloader.limit_batches.training=20",
                "dataloader.limit_batches.validation=20",
                "dataloader.num_workers.training=8",
                "dataloader.num_workers.validation=8",
                
            ]
        },
    ]
}